{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "properties": {
        "experiment_name": {
            "type": "string",
            "description": "The name of the experiment (eg Yuliya-vida-finetune)."
        },
        "run_id": {
            "type": "string",
            "description": "The run ID of the experiment (eg 2024-06-17_15-30-00)."
        },
        "image_pairs": {
            "type": "array",
            "description": "An array of image pairs",
            "items": {
                "type": "object",
                "properties": {
                    "scene_id": {
                        "type": "string",
                        "description": "The ID of the scene (eg scene_001)."
                    },
                    "text_description": {
                        "type": "string",
                        "description": "The text description of the image (eg Image A is has better sharpness then image B)."
                    }
                },
                "required": ["scene_id", "text_description"]
            }
        },
        "metadata": {
            "type": "object",
            "description": "Additional metadata for the experiment (optional)."
        }
    },
    "required": ["experiment_name", "run_id", "image_pairs"]
}

